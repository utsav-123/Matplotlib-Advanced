import matplotlib.colors as mcolors
import matplotlib.pyplot as plt
from matplotlib import animation
from IPython.display import HTML
import numpy as np

ssp_anim = 'ssp585'

# --- Load DEM and compute hillshade ---
with xr.open_dataset(gdir.get_filepath('gridded_data')) as ds_grid:
    ds_grid = ds_grid.load()

dem = ds_grid['topo'].values  # DEM elevation

def hillshade(dem, azimuth=315, altitude=45):
    """Compute hillshade from DEM."""
    azimuth_rad = np.deg2rad(360 - azimuth)
    altitude_rad = np.deg2rad(altitude)

    # Gradient
    dy, dx = np.gradient(dem)
    slope = np.arctan(np.sqrt(dx**2 + dy**2))
    aspect = np.arctan2(-dy, dx)

    # Hillshade formula
    shade = (np.sin(altitude_rad) * np.cos(slope) +
             np.cos(altitude_rad) * np.sin(slope) *
             np.cos(azimuth_rad - aspect))
    shade = np.clip(shade, 0, 1)
    return shade

hs = hillshade(dem, azimuth=315, altitude=45)

# --- Stack GCMs and compute ensemble mean ---
stacked = np.stack([
    ds_cmip[member][ssp_anim].simulated_thickness.values
    for member in members
], axis=0)
mean_thk = stacked.mean(axis=0)  # (time, y, x)

# Trim to post-RGI date
time_coords = ds_cmip[members[0]][ssp_anim].simulated_thickness.time.values
time_mask   = time_coords >= gdir.rgi_date
mean_thk    = mean_thk[time_mask]
time_coords = time_coords[time_mask]

# --- Build masked ice thickness (transparent where no ice) ---
def get_ice_rgba(thk_frame, cmap_name='Blues', vmax=300):
    """Convert thickness array to RGBA, transparent where ice = 0."""
    norm   = mcolors.Normalize(vmin=0, vmax=vmax)
    cmap   = plt.cm.get_cmap(cmap_name)
    rgba   = cmap(norm(thk_frame))
    # Set alpha=0 where no ice
    rgba[..., 3] = np.where(thk_frame > 1, 0.85, 0)
    return rgba

# --- Set up figure ---
fig, ax = plt.subplots(figsize=(8, 7), dpi=120)
ax.axis('off')

# Layer 1: DEM colored by elevation (terrain colormap)
dem_plot = ax.imshow(dem, cmap='terrain', origin='lower',
                     vmin=dem.min(), vmax=dem.max(), zorder=1)

# Layer 2: Hillshade overlay (semi-transparent grey)
hs_plot = ax.imshow(hs, cmap='gray', origin='lower',
                    vmin=0, vmax=1, alpha=0.4, zorder=2)

# Layer 3: Ice thickness (Blues, transparent where no ice)
ice_rgba = get_ice_rgba(mean_thk[0])
ice_plot = ax.imshow(ice_rgba, origin='lower', zorder=3)

# Colorbar for ice thickness
sm = plt.cm.ScalarMappable(cmap='Blues',
                            norm=mcolors.Normalize(vmin=0, vmax=300))
sm.set_array([])
cbar = plt.colorbar(sm, ax=ax, fraction=0.03, pad=0.02)
cbar.set_label('Ice Thickness [m]', fontsize=10)

# Year text on plot
year_text = ax.text(0.02, 0.97, '', transform=ax.transAxes,
                    fontsize=13, fontweight='bold', color='white',
                    va='top', ha='left',
                    bbox=dict(boxstyle='round,pad=0.3',
                              facecolor='black', alpha=0.5))

# SSP label
ax.text(0.02, 0.90, f'{ssp_labels[ssp_anim]} | 4-GCM Ensemble Mean',
        transform=ax.transAxes, fontsize=9, color='white',
        va='top', ha='left',
        bbox=dict(boxstyle='round,pad=0.3', facecolor='black', alpha=0.4))

ax.set_title('Lumding Glacier — Ice Thickness Evolution', fontsize=13, pad=10)

def animate(frame):
    ice_rgba = get_ice_rgba(mean_thk[frame])
    ice_plot.set_array(ice_rgba)
    year_text.set_text(f'Year: {float(time_coords[frame]):.0f}')

ani_glacier = animation.FuncAnimation(
    fig, animate, frames=len(time_coords), interval=120
)
HTML(ani_glacier.to_jshtml())




# Save animation as mp4
FFwriter = animation.FFMpegWriter(fps=5)
ani_glacier.save('Lumding_CMIP6_ensemble_ssp585_Hillshade.mp4', writer=FFwriter)
print(f'Saved to: {os.getcwd()}')
