# Interpolate SSP2-4.5 as the average of SSP1-2.6 and SSP3-7.0
# SSP2-4.5 (~2.7C by 2100) lies almost exactly halfway
# between SSP1-2.6 (~1.8C) and SSP3-7.0 (~3.6C)
for member in members:
    thk_126 = ds_cmip[member]['ssp126'].simulated_thickness
    thk_370 = ds_cmip[member]['ssp370'].simulated_thickness
    thk_245 = (thk_126 + thk_370) / 2.0

    ds_245 = ds_cmip[member]['ssp126'].copy(deep=True)
    ds_245['simulated_thickness'] = thk_245
    ds_cmip[member]['ssp245'] = ds_245

